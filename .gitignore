# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Distribution
build/
dist/
*.egg-info/
*.egg

# Data — never commit raw, interim or processed datasets (large + license-sensitive).
# Only the placeholder .gitkeep files are tracked so the folder layout is preserved.
data/raw/*
data/interim/*
data/processed/*
data/external/*
data/db/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!data/db/.gitkeep

# DuckDB
*.duckdb
*.duckdb.wal

# Environment / secrets
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
